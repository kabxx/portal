{
  "name": "portal",
  "version": "1.0.0",
  "private": true,
  "description": "A browser-backed terminal agent for web AI products and local tools.",
  "scripts": {
    "dev": "tsx src/index.ts",
    "lint": "eslint . --max-warnings 0",
    "test": "npm run test:type && npm run test:unit",
    "test:type": "tsc -p tsconfig.json --noEmit",
    "test:unit": "node --import tsx --test \"test/**/*.test.ts\"",
    "test:browser": "node --import tsx --test --test-timeout=90000 \"test/browser/**/*.smoke.ts\"",
    "test:coverage": "node --experimental-test-coverage --test-coverage-include=\"src/**\" --test-coverage-exclude=\"test/**\" --import tsx --test \"test/**/*.test.ts\"",
    "fmt": "prettier . --write",
    "fmt:check": "prettier . --check",
    "prepare": "husky"
  },
  "lint-staged": {
    "*": "prettier --ignore-unknown --write"
  },
  "keywords": [
    "browser-automation",
    "cli",
    "playwright",
    "web-ai"
  ],
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/express": "5.0.6",
    "@types/node": "^24.13.3",
    "eslint": "10.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "3.8.3",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "8.64.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.2.16",
    "7zip-bin": "^5.2.0",
    "better-sqlite3": "^12.11.1",
    "commander": "^14.0.3",
    "fastify": "^5.10.0",
    "fs-native-extensions": "1.5.0",
    "ink": "git+https://github.com/kabxx/ink4portal.git#3764659a0965c9289ad33814449e3cdf805fac9d",
    "koffi": "^3.0.2",
    "markdansi": "github:kabxx/Markdansi4portal#c075195137fbf91b9d610543a999bf5913730859",
    "node-unrar-js": "^2.0.2",
    "playwright": "^1.59.1",
    "react": "^19.2.7",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  }
}
