{
  "name": "portal",
  "version": "1.0.0",
  "private": true,
  "description": "A browser-backed terminal agent for web AI products and local tools.",
  "scripts": {
    "dev": "tsx src/index.ts",
    "test": "npm run test:type && npm run test:unit",
    "test:type": "tsc -p tsconfig.json --noEmit",
    "test:unit": "node --import tsx --test \"test/**/*.test.ts\"",
    "test:coverage": "node --experimental-test-coverage --test-coverage-include=\"src/**\" --test-coverage-exclude=\"test/**\" --import tsx --test \"test/**/*.test.ts\"",
    "fmt": "prettier . --write",
    "fmt:check": "prettier . --check"
  },
  "keywords": [
    "browser-automation",
    "cli",
    "playwright",
    "web-ai"
  ],
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "prettier": "3.8.3",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.2.16",
    "7zip-bin": "^5.2.0",
    "better-sqlite3": "^12.11.1",
    "commander": "^14.0.3",
    "fastify": "^5.10.0",
    "ink": "github:kabxx/ink4portal#5cae5492d8d26162225612af06abab23ce9a3bbd",
    "koffi": "^3.0.2",
    "markdansi": "github:kabxx/Markdansi4portal#c075195137fbf91b9d610543a999bf5913730859",
    "node-unrar-js": "^2.0.2",
    "playwright": "^1.59.1",
    "react": "^19.2.7",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  }
}
